// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  image         String?
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]
  salaryEntries SalaryEntry[]
  createdAt     DateTime       @default(now())
}

model SalaryEntry {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])

  // Core fields
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  role         String   // e.g. "Software Engineer"
  level        String   // e.g. "L4", "SDE-2", "Senior"
  location     String   // e.g. "Bangalore", "Remote"

  // Compensation (all in USD or INR — track currency)
  currency     String   @default("INR")
  baseSalary   Float
  bonus        Float    @default(0)   // annual bonus
  stockValue   Float    @default(0)   // annual stock (total/4 if 4yr vest)
  totalComp    Float    // computed: base + bonus + stock

  // Meta
  yearsExp     Int?
  source       String   @default("user") // "user" | "seed"
  createdAt    DateTime @default(now())

  @@index([companyId])
  @@index([level])
  @@index([location])
}

model Company {
  id           String        @id @default(cuid())
  name         String        @unique  // canonical name e.g. "Google"
  aliases      String[]      // ["google inc", "google llc", "alphabet"]
  industry     String?
  hq           String?
  salaryEntries SalaryEntry[]
  createdAt    DateTime      @default(now())
}

// NextAuth required models below
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}